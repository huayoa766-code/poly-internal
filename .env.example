# Database — PostgreSQL (e.g. Neon). Use the DIRECT connection string.
# Example: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Dashboard PIN gate (web UI). Set a 6-digit PIN to require it before the
# dashboard loads; leave blank to disable the gate entirely.
DASHBOARD_PIN=""
# Secret used to sign the login session cookie. Use any long random string,
# e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`.
AUTH_SECRET=""

# Telegram notifications. Leave blank to run in DRY-RUN (alerts print to console).
# 1) Create a bot via @BotFather -> get the token
# 2) Message your bot, then get your chat id (see README)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Alert tuning (all optional; defaults shown)
PRICE_MOVE_THRESHOLD="0.05"   # fire when primary outcome moves >= 5 points
DEADLINE_HOURS="24"           # warn when a market closes within N hours
NEWS_TIMESPAN="1h"            # GDELT lookback window per pass
MAX_NEWS_PER_MARKET="3"       # cap headlines per market per alert

# Worker schedules (cron syntax)
POLL_CRON="*/15 * * * *"      # alert pass every 15 minutes
DIGEST_CRON="0 9 * * *"       # daily digest at 09:00
